# ---------------------------------------------------------------------------
# jobbot configuration. Copy to .env and fill in. NEVER commit .env.
# ---------------------------------------------------------------------------

ENVIRONMENT=development
LOG_LEVEL=INFO
LOG_JSON=false

# --- Discord ---------------------------------------------------------------
# Create a bot at https://discord.com/developers/applications, enable the
# "applications.commands" and "bot" scopes, and paste the token here.
DISCORD_TOKEN=your-bot-token
# Comma-separated guild ids for instant slash-command sync during development.
# Leave empty in production to sync commands globally (can take up to 1h).
DISCORD_GUILD_IDS=
# Roles (besides server Administrators) allowed to run config commands.
DISCORD_MANAGER_ROLE_IDS=

# --- Database --------------------------------------------------------------
# Default: local SQLite file — zero external services, no Docker needed.
DATABASE_URL=sqlite+aiosqlite:///jobbot.db
# For production / multiple instances, use Postgres instead:
# DATABASE_URL=postgresql+asyncpg://jobbot:jobbot@localhost:5432/jobbot

# --- Search providers ------------------------------------------------------
# Ordered; first with remaining quota is used, the rest are fallbacks.
# Options: serper, bing, brave, google_pse, mock
SEARCH_PROVIDERS=serper
SERPER_API_KEY=
BING_API_KEY=
BRAVE_API_KEY=
GOOGLE_PSE_API_KEY=
GOOGLE_PSE_CX=

# Use the mock provider to exercise the pipeline with no API key:
# SEARCH_PROVIDERS=mock

# --- Quotas / budgets ------------------------------------------------------
DAILY_SEARCH_BUDGET=1000
HOURLY_SEARCH_BUDGET=100
RESULTS_PER_QUERY=10
MAX_QUERIES_PER_SCAN=40

# --- Scheduling ------------------------------------------------------------
SCAN_INTERVAL_HOURS=6
EXPIRATION_RECHECK_HOURS=24
SCAN_ENABLED=true

# --- HTTP / safety ---------------------------------------------------------
HTTP_TIMEOUT_SECONDS=15
HTTP_USER_AGENT=jobbot/0.1 (+https://github.com/example/jobbot)
# Keep false in production to block SSRF to private ranges.
ALLOW_PRIVATE_NETWORKS=false

# --- Relevance -------------------------------------------------------------
DEFAULT_MIN_SCORE=0.55
ENABLE_LLM_CLASSIFICATION=false
ANTHROPIC_API_KEY=
LLM_MODEL=claude-haiku-4-5-20251001

# --- Health check ----------------------------------------------------------
HEALTH_HOST=0.0.0.0
HEALTH_PORT=8080
